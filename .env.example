# Required: URL of the Actual sync-server (the actual-server container itself,
# NOT the v1 actual-http-api proxy).
ACTUAL_SERVER_URL=http://actual-budget:5006

# Required: Password used to log into actual-server.
ACTUAL_SERVER_PASSWORD=your-actual-server-password

# Required: Budget sync ID (Actual UI -> Settings -> Advanced -> Sync ID).
ACTUAL_BUDGET_SYNC_ID=your-budget-sync-id

# Optional: only required if your budget is end-to-end encrypted.
# ACTUAL_BUDGET_ENCRYPTION_PASSWORD=your-e2ee-password

# Required when MCP_TRANSPORT is http or sse. Comma-separated bearer tokens.
# Each token MUST be at least 32 characters AND contain at least 16 unique
# characters (enforced at startup). Generate with e.g.:
#   openssl rand -base64 48 | tr -d '\n=+/' | cut -c1-48
MCP_API_KEYS=your-first-token-min-32-chars-and-16-unique,your-second-token-here

# Recommended in production: comma-separated list of allowed Origin headers
# for browser-based MCP clients. Leave empty to allow any origin (CLI / desktop
# clients that don't send Origin are always allowed).
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://app.example.com

# Optional: Transport mode (stdio | sse | http). Default: stdio.
# Note: SSE is deprecated and slated for removal in v2.1 — prefer http.
MCP_TRANSPORT=stdio

# Optional: Port for SSE/HTTP transport. Default: 3000.
MCP_PORT=3000

# Optional: Currency symbol used when formatting amounts. Default: $
CURRENCY_SYMBOL=$

# Optional: Log level (debug | info | warn | error). Default: info
LOG_LEVEL=info
